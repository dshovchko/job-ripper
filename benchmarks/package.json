{
  "name": "job-ripper-benchmarks",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:compress": "bash run-bench.sh -s compress-hash-js -p \"node_modules/**/*.js\" -f \"*.js\"",
    "bench:md-html": "bash run-bench.sh -s md-to-html -p \"node_modules/**/*.md\" -f \"*.md\"",
    "bench:json": "bash run-bench.sh -s validate-json -p \"node_modules/**/package.json\" -f \"package.json\""
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "fdir": "^6.5.0",
    "findx-cli": "^0.2.2",
    "glob": "^13.0.6",
    "globby": "^16.2.0",
    "picomatch": "^4.0.4",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tinyglobby": "^0.2.16",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
